{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "tap_mssql",
      "justMyCode": false,
      "args": [
        "--config",
        ".secrets/config.json",
        "--catalog",
        ".secrets/catalog.json",
        "--state",
        ".secrets/state.json"
      ]
    },
    {
      "name": "Run (Save)",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "tap_mssql",
      "justMyCode": false,
      "args": [
        "--config",
        ".secrets/config.json",
        "--catalog",
        ".secrets/catalog.json",
        "--state",
        ".secrets/state.json",
        ">",
        ".secrets/output.jsonl"
      ]
    },
    {
      "name": "Discover",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "tap_mssql",
      "justMyCode": false,
      "args": [
        "--config",
        ".secrets/config.json",
        "--discover",
        ">",
        ".secrets/catalog.json"
      ]
    }
  ]
}
