    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "tap_mssql",
            "justMyCode": false,
            "args": [
                "--config",
                ".secrets/config.json",
                "--catalog",
                ".secrets/catalog.json",
                "--state",
                ".secrets/state.json",
            ]
        },
        {
            "name": "Run (Save)",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "tap_mssql",
            "justMyCode": false,
            "args": [
                "--config",
                ".secrets/config.json",
                "--catalog",
                ".secrets/catalog.json",
                "--state",
                ".secrets/state.json",
                ">",
                "output/data.jsonl",
            ]
        },
        {
            "name": "Discover",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "tap_mssql",
            "justMyCode": false,
            "args": [
                "--config",
                ".secrets/config.json",
                "--discover",
                ">",
                "output/catalog.json",
            ]
        },
    ]
}